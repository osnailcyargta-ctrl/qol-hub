<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="QoL Hub"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/orange"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Quality of Life Tools"
            android:textSize="13sp"
            android:textColor="@color/gray"
            android:layout_marginBottom="24dp"/>

        <!-- SCREEN TIMER CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1A1A1A"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="&#9201;  Screen Timer"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/orange"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Auto lock screen after timer ends."
                android:textSize="12sp"
                android:textColor="@color/gray"
                android:layout_marginBottom="12dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <EditText
                    android:id="@+id/et_timer_value"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:inputType="number"
                    android:hint="Value"
                    android:textColor="@color/white"
                    android:textColorHint="@color/gray"
                    android:backgroundTint="@color/orange"
                    android:padding="8dp"
                    android:layout_marginEnd="8dp"/>

                <Spinner
                    android:id="@+id/spinner_timer_unit"
                    android:layout_width="120dp"
                    android:layout_height="wrap_content"
                    android:backgroundTint="@color/orange"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_timer_start"
                    style="@style/OrangeButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Start"
                    android:layout_marginEnd="8dp"/>

                <Button
                    android:id="@+id/btn_timer_stop"
                    style="@style/StopButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Stop"/>
            </LinearLayout>
        </LinearLayout>

        <!-- SCREEN TIME CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1A1A1A"
            android:padding="16dp"
            android:layout_marginBottom="32dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="&#128202;  App Screen Time"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/orange"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Today's usage — foreground vs background."
                android:textSize="12sp"
                android:textColor="@color/gray"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Top 3 Today"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:layout_marginBottom="8dp"/>

            <LinearLayout
                android:id="@+id/ll_top3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"/>

            <TextView
                android:id="@+id/tv_screentime_no_permission"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Usage Access permission needed.\nTap to grant."
                android:textColor="@color/gray"
                android:textSize="13sp"
                android:gravity="center"
                android:padding="16dp"
                android:visibility="gone"/>

        </LinearLayout>

    </LinearLayout>
</ScrollView>
